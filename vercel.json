{
  "installCommand": "npm install",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/d",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ],
  "functions": {
    "api/products/codediff/compare.ts": { "maxDuration": 30 },
    "api/products/email-validation/validate.ts": { "maxDuration": 30 },
    "api/products/lambda/simulate.js": { "maxDuration": 30 },
    "api/products/postman-to-swagger/convert.ts": { "maxDuration": 30 },
    "api/products/readtime.js": { "maxDuration": 30 },
    "api/products/coot-parser.js": { "maxDuration": 60 },
    "api/products/page-speed/pagespeed.ts": { "maxDuration": 60 },
    "api/products/tsukiyomi.ts": {
      "maxDuration": 60,
      "includeFiles": "products/Tsukiyomi-Platform/apps/server/dist/**,products/Tsukiyomi-Platform/apps/server/GBA_Roms_Names.json,products/Tsukiyomi-Platform/apps/server/GBA_Roms_Genres.json,products/Tsukiyomi-Platform/apps/server/Images/**"
    }
  },
  "rewrites": [
    { "source": "/about", "destination": "/index.html" },
    { "source": "/projects", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" },
    { "source": "/project/:slug", "destination": "/products/:slug/" },
    { "source": "/project/:slug/", "destination": "/products/:slug/" },
    { "source": "/project/:slug/:path*", "destination": "/products/:slug/:path*" },

    { "source": "/products/codediff/api/compare", "destination": "/api/products/codediff/compare" },
    { "source": "/products/lambda/api/simulate", "destination": "/api/products/lambda/simulate" },
    { "source": "/products/email-validation/api/validate", "destination": "/api/products/email-validation/validate" },
    { "source": "/products/postman-to-swagger/convert", "destination": "/api/products/postman-to-swagger/convert" },
    { "source": "/products/page-speed/api/pagespeed", "destination": "/api/products/page-speed/pagespeed" },
    { "source": "/products/tsukiyomi/api/:path*", "destination": "/api/products/tsukiyomi" },
    { "source": "/products/tsukiyomi/Images/:path*", "destination": "/products/Tsukiyomi-Platform/apps/server/Images/:path*" },

    { "source": "/products/canvas-games/", "destination": "/products/Canvas-Js-Games/public/index.html" },
    { "source": "/products/canvas-games/flappy-bird", "destination": "/products/Canvas-Js-Games/flappy-bird/index.html" },
    { "source": "/products/canvas-games/flappy-bird/", "destination": "/products/Canvas-Js-Games/flappy-bird/index.html" },
    { "source": "/products/canvas-games/flappy-bird/:path*", "destination": "/products/Canvas-Js-Games/flappy-bird/:path*" },
    { "source": "/products/canvas-games/space-shooter", "destination": "/products/Canvas-Js-Games/space-shooter/index.html" },
    { "source": "/products/canvas-games/space-shooter/", "destination": "/products/Canvas-Js-Games/space-shooter/index.html" },
    { "source": "/products/canvas-games/space-shooter/:path*", "destination": "/products/Canvas-Js-Games/space-shooter/:path*" },
    { "source": "/products/canvas-games/:path*", "destination": "/products/Canvas-Js-Games/public/:path*" },

    { "source": "/products/background-remover/", "destination": "/products/BackgroundRemover/public/index.html" },
    { "source": "/products/background-remover/:path*", "destination": "/products/BackgroundRemover/public/:path*" },
    { "source": "/products/codediff/", "destination": "/products/CodeDiff/public/index.html" },
    { "source": "/products/codediff/:path*", "destination": "/products/CodeDiff/public/:path*" },
    { "source": "/products/coot-parser/api/:path*", "destination": "/api/products/coot-parser" },
    { "source": "/products/coot-parser/health", "destination": "/api/products/coot-parser" },
    { "source": "/products/coot-parser/parse/:path*", "destination": "/api/products/coot-parser" },
    { "source": "/products/coot-parser/compose", "destination": "/api/products/coot-parser" },
    { "source": "/products/coot-parser/split", "destination": "/api/products/coot-parser" },
    { "source": "/products/coot-parser/fixtures/:path*", "destination": "/api/products/coot-parser" },
    { "source": "/products/coot-parser/", "destination": "/bundled-products/coot-parser/index.html" },
    { "source": "/products/coot-parser/:path*", "destination": "/bundled-products/coot-parser/:path*" },
    { "source": "/products/django-learning/", "destination": "/bundled-products/django-learning/index.html" },
    { "source": "/products/django-learning/:path*", "destination": "/bundled-products/django-learning/:path*" },
    { "source": "/products/email-validation/", "destination": "/bundled-products/email-validation/index.html" },
    { "source": "/products/email-validation/:path*", "destination": "/bundled-products/email-validation/:path*" },
    { "source": "/products/tracktemp/", "destination": "/products/ESP8266-DHT11-Google-Sheets-Logger/public/index.html" },
    { "source": "/products/tracktemp/:path*", "destination": "/products/ESP8266-DHT11-Google-Sheets-Logger/public/:path*" },
    { "source": "/products/lambda/", "destination": "/bundled-products/lambda/index.html" },
    { "source": "/products/lambda/:path*", "destination": "/bundled-products/lambda/:path*" },
    { "source": "/products/lumina/", "destination": "/products/lumina/public/index.html" },
    { "source": "/products/lumina/:path*", "destination": "/products/lumina/public/:path*" },
    { "source": "/products/postman-to-swagger/", "destination": "/bundled-products/postman-to-swagger/index.html" },
    { "source": "/products/postman-to-swagger/:path*", "destination": "/bundled-products/postman-to-swagger/:path*" },
    { "source": "/products/readtime/readtime", "destination": "/api/products/readtime" },
    { "source": "/products/readtime/", "destination": "/bundled-products/readtime/index.html" },
    { "source": "/products/readtime/:path*", "destination": "/bundled-products/readtime/:path*" },
    { "source": "/products/svg-palette/", "destination": "/bundled-products/svg-palette/index.html" },
    { "source": "/products/svg-palette/:path*", "destination": "/bundled-products/svg-palette/:path*" },
    { "source": "/products/talkative/", "destination": "/bundled-products/talkative/index.html" },
    { "source": "/products/talkative/:path*", "destination": "/bundled-products/talkative/:path*" },
    { "source": "/products/transcribe/", "destination": "/products/transcribe/public/index.html" },
    { "source": "/products/transcribe/:path*", "destination": "/products/transcribe/public/:path*" },
    { "source": "/products/tsukiyomi/", "destination": "/bundled-products/tsukiyomi/index.html" },
    { "source": "/products/tsukiyomi/:path*", "destination": "/bundled-products/tsukiyomi/:path*" },
    { "source": "/products/page-speed/", "destination": "/bundled-products/page-speed/index.html" },
    { "source": "/products/page-speed/:path*", "destination": "/bundled-products/page-speed/:path*" },
    { "source": "/products/wingman/", "destination": "/products/wingman/public/index.html" },
    { "source": "/products/wingman/:path*", "destination": "/products/wingman/public/:path*" },
    { "source": "/products/xbat/", "destination": "/products/XBat/public/index.html" },
    { "source": "/products/xbat/:path*", "destination": "/products/XBat/public/:path*" }
  ],
  "redirects": [
    { "source": "/project/:slug", "destination": "/project/:slug/", "permanent": true },
    { "source": "/products/background-remover", "destination": "/products/background-remover/", "permanent": true },
    { "source": "/products/canvas-games", "destination": "/products/canvas-games/", "permanent": true },
    { "source": "/products/codediff", "destination": "/products/codediff/", "permanent": true },
    { "source": "/products/coot-parser", "destination": "/products/coot-parser/", "permanent": true },
    { "source": "/products/django-learning", "destination": "/products/django-learning/", "permanent": true },
    { "source": "/products/email-validation", "destination": "/products/email-validation/", "permanent": true },
    { "source": "/products/tracktemp", "destination": "/products/tracktemp/", "permanent": true },
    { "source": "/products/lambda", "destination": "/products/lambda/", "permanent": true },
    { "source": "/products/lumina", "destination": "/products/lumina/", "permanent": true },
    { "source": "/products/postman-to-swagger", "destination": "/products/postman-to-swagger/", "permanent": true },
    { "source": "/products/readtime", "destination": "/products/readtime/", "permanent": true },
    { "source": "/products/svg-palette", "destination": "/products/svg-palette/", "permanent": true },
    { "source": "/products/talkative", "destination": "/products/talkative/", "permanent": true },
    { "source": "/products/transcribe", "destination": "/products/transcribe/", "permanent": true },
    { "source": "/products/tsukiyomi", "destination": "/products/tsukiyomi/", "permanent": true },
    { "source": "/products/page-speed", "destination": "/products/page-speed/", "permanent": true },
    { "source": "/products/wingman", "destination": "/products/wingman/", "permanent": true },
    { "source": "/products/xbat", "destination": "/products/xbat/", "permanent": true }
  ]
}
